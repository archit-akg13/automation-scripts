"""
Cron Scheduler - A lightweight, pure-Python task scheduler.
Schedule recurring jobs with interval-based or daily-at-time triggers.
No external dependencies required.
"""

import time
import threading
import logging
from datetime import datetime
from typing import Callable, Optional
from dataclasses import dataclass, field

logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(message)s")
logger = logging.getLogger(__name__)


@dataclass
class Job:
      """Represents a scheduled job."""
      name: str
      func: Callable
      interval_seconds: Optional[float] = None
      run_at_time: Optional[str] = None
      last_run: Optional[datetime] = None
      run_count: int = 0
      max_runs: Optional[int] = None
      tags: list[str] = field(default_factory=list)

    @property
    def is_expired(self) -> bool:
              return self.max_runs is not None and self.run_count >= self.max_runs

    def should_run(self, now: datetime) -> bool:
              if self.is_expired:
                            return False
                        if self.interval_seconds is not None:
                                      if self.last_run is None:
                                                        return True
                                                    return (now - self.last_run).total_seconds() >= self.interval_seconds
        if self.run_at_time is not None:
                      current_time = now.strftime("%H:%M")
            if current_time == self.run_at_time:
                              if self.last_run is None or self.last_run.date() < now.date():
                                                    return True
                                        return False

    def execute(self) -> None:
              try:
                            logger.info(f"Running job: {self.name}")
                            self.func()
                            self.last_run = datetime.now()
                            self.run_count += 1
                            logger.info(f"Completed: {self.name} (run #{self.run_count})")
except Exception as exc:
              logger.error(f"Job {self.name} failed: {exc}")


class Scheduler:
      """Lightweight task scheduler with decorator-based job registration."""

    def __init__(self):
              self._jobs: list[Job] = []
              self._running = False
              self._lock = threading.Lock()

    def every(self, seconds=0, minutes=0, hours=0, max_runs=None, tags=None):
              """Decorator: run a function at a fixed interval."""
              total = seconds + (minutes * 60) + (hours * 3600)
              if total <= 0:
                            raise ValueError("Interval must be positive")
                        def decorator(func):
                                      job = Job(name=func.__name__, func=func, interval_seconds=total,
                                                                      max_runs=max_runs, tags=tags or [])
                                      with self._lock:
                                                        self._jobs.append(job)
                                                    return func
        return decorator

    def daily(self, at="00:00", max_runs=None, tags=None):
              """Decorator: run a function once per day at HH:MM."""
        def decorator(func):
                      job = Job(name=func.__name__, func=func, run_at_time=at,
                                                      max_runs=max_runs, tags=tags or [])
            with self._lock:
                              self._jobs.append(job)
            return func
        return decorator

    def cancel(self, name: str) -> bool:
              with self._lock:
                            before = len(self._jobs)
            self._jobs = [j for j in self._jobs if j.name != name]
            return len(self._jobs) < before

    def status(self) -> list[dict]:
              return [{"name": j.name, "runs": j.run_count, "expired": j.is_expired}
                                      for j in self._jobs]

    def _tick(self):
              now = datetime.now()
        with self._lock:
                      active = [j for j in self._jobs if not j.is_expired]
        for job in active:
                      if job.should_run(now):
                                        job.execute()

    def run(self, poll_interval=1.0):
              self._running = True
        logger.info(f"Scheduler started with {len(self._jobs)} job(s)")
        try:
                      while self._running:
                                        self._tick()
                                        time.sleep(poll_interval)
except KeyboardInterrupt:
            self._running = False

    def run_in_background(self, poll_interval=1.0):
              t = threading.Thread(target=self.run, args=(poll_interval,), daemon=True)
        t.start()
        return t

    def stop(self):
              self._running = False


if __name__ == "__main__":
      scheduler = Scheduler()

    @scheduler.every(seconds=10, tags=["monitoring"])
    def heartbeat():
              print(f"[{datetime.now().strftime('%H:%M:%S')}] OK")

    @scheduler.daily(at="09:00", tags=["reporting"])
    def daily_summary():
              print("Generating daily summary...")

    print("Jobs:", [j["name"] for j in scheduler.status()])
    scheduler.run()
